// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `zed: Open Default Settings` command
// from the command palette
{
    // "base_keymap": "JetBrains",
    "edit_predictions": {
        "provider": "ollama"
    },
    "agent": {
        "default_model": {
            "provider": "ollama",
            "model": "qwen2.5-coder:latest",
        },
    },
    "vim_mode": true,
    "ui_font_size": 15,
    "buffer_font_family": "Google Sans Code NF",
    "buffer_font_size": 15,
    "buffer_font_weight": 400,
    "theme": {
        "mode": "light", // system, dark, light
        "light": "Xcode Spartan",
        "dark": "Aura Dark (Soft Text)",
    },
    "lsp": {
        "jdtls": {
            "initialization_options": {
                "settings": {
                    "java": {
                        "settings": {
                            "java.jdt.ls.lombokSupport.enabled:": true,
                        },
                        "jdt": {
                            "ls": {
                                "lombokSupport": {
                                    "enabled": true,
                                },
                            },
                        },
                        "referencesCodeLens": {
                            "enabled": true,
                        },
                        "signatureHelp": {
                            "enabled": true,
                        },
                        "implementationsCodeLens": {
                            "enabled": true,
                        },
                        "format": {
                            "enabled": true,
                        },
                        "contentProvider": {
                            "preferred": null,
                        },
                        "autobuild": {
                            "enabled": false,
                        },
                    },
                },
            },
        },
    },
    "languages": {
        "TSX": {
            "code_actions_on_format": {
                "source.organizeImports": true,
            },
        },
        "JavaScript": {
            "format_on_save": "on",
            "formatter": "prettier",
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
        },
        "Java": {
            "formatter": "language_server",
            "tab_size": 4,
            "format_on_save": "on",
        },
        "Gleam": {
            "formatter": "language_server",
        },
    },
    "prettier": {
        "allowed": true,
        // "arguments": ["--stdin-filepath", "{buffer_path}"],
        "plugins": ["prettier-plugin-tailwindcss"],
        "trailingComma": "es5",
        "tabWidth": 4,
        "semi": false,
        "singleQuote": true,
    },
    "journal": {
        "path": "~",
        "hour_format": "hour24",
    },
    "git": {
        "inline_blame": {
            "enabled": false,
        },
    },
    "file_scan_exclusions": ["**/.git", "**/.classpath", "**/.settings"],
}
